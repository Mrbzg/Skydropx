# ============================================================================
# Agente Fénix v5 — Configuración (.env)
# ============================================================================
# Copia este archivo a `.env` y rellena tus valores:
#     cp .env.example .env
#
# Solo DENUE_TOKEN es OBLIGATORIO para arrancar. El resto es opcional.
# ============================================================================


# ───────────── OBLIGATORIO ─────────────
# Token gratuito de INEGI/DENUE: https://www.inegi.org.mx/app/api/denue/v1/tutorial.html
DENUE_TOKEN=tu_token_inegi_aqui


# ───────────── BASE DE DATOS (modo DUAL: SQLite + Supabase) ─────────────
#
# Arquitectura dual-mode:
#   • SQLite  = base LOCAL y "source of truth". El pipeline siempre escribe aquí
#               (rápido, sin red, funciona offline). Default, no requiere nada.
#   • Supabase = espejo CLOUD opcional para backup, dashboards y acceso remoto.
#               Se sincroniza con `fenix sync push` o de forma automática.
#
# Ambos conviven sin problema: SQLite local + Supabase remoto.

# --- SQLite (local, siempre activo) ---
SQLITE_PATH=data/fenix.sqlite       # default OK

# --- Supabase (cloud, opcional) ---
# Obtén estos valores en: Supabase Dashboard → Settings → API
#   SUPABASE_URL  = "Project URL"      (https://xxxxx.supabase.co)
#   SUPABASE_KEY  = "service_role key" (secreta; permite upserts/escrituras)
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Si =true, el pipeline empuja a Supabase automáticamente al terminar cada corrida.
# Déjalo en false para sincronizar manualmente con `fenix sync push`.
SUPABASE_AUTO_SYNC=false

# (Avanzado) Postgres self-hosted en lugar de SQLite — normalmente NO necesario.
# Para casi todos los casos, usa SQLite local + Supabase cloud.
# DATABASE_URL=postgresql://fenix:fenix_local@localhost:5432/fenix


# ───────────── SEARCH BACKENDS (opcional, recomendado) ─────────────
# Serper.dev: 2,500 búsquedas Google gratis (https://serper.dev/api-key)
# SERPER_API_KEY=tu_serper_key
SERPER_STRATEGY=reserve              # usa Serper solo cuando los gratis fallan
SERPER_STOP_WHEN_PAID=true
# SEARXNG_URL=http://localhost:8888   # si levantaste SearXNG en Docker (docker compose up -d searxng)
# OPENSERP_URL=http://localhost:7000
SEARCH_MODE=cascade
SEARCH_AVOID_PAID=true


# ───────────── OUTPUT ─────────────
OUTPUT_DIR=output
EXPORT_DEFAULT_FORMAT=both           # csv | json | both


# ───────────── MODO / LOGGING ─────────────
FENIX_MODE=sin-ia                    # sin-ia | con-ia
AI_PARSER_ENABLED=false
LOG_LEVEL=INFO


# ───────────── MERCADO LIBRE (opcional) ─────────────
# ML_APP_ID=
# ML_CLIENT_SECRET=


# ───────────── COMPLIANCE / SCRAPING ─────────────
RESPECT_ROBOTS_TXT=true
USER_AGENT=AgenteFenix/5.0 (research; +https://skydropx.com)
ROTATE_USER_AGENTS=true
MAX_REQUESTS_PER_SECOND=2


# ───────────── CRM (opcional) ─────────────
# HUBSPOT_API_KEY=
# GOOGLE_SHEETS_CREDS=


# ───────────── PROXIES (opcional) ─────────────
# HTTP_PROXY=socks5://localhost:9050
# HTTPS_PROXY=socks5://localhost:9050
USE_FREE_PROXIES=false
